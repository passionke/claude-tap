# claw-tap (claude-tap) — copy to `.env` and edit.
# Author: kejiqing
#
# Tap-only variables. Gateway / pool / worker env → claw-code
# (deploy/stack/env.local.example).

# Listen ports (docker compose)
CLAUDE_TAP_PORT=8080
CLAUDE_TAP_LIVE_PORT=3000

# =============================================================================
# claw-code stack: tap reads upstream ONLY from PostgreSQL
# =============================================================================
# Must match http-gateway-rs. Active model lives in:
#   gateway_llm_cluster_state / gateway_llm_cluster_revision
# Tap does NOT use --tap-target, OPENAI_BASE_URL, or UPSTREAM_OPENAI_BASE_URL here.
# Upstream LLM URL and API key are loaded from PostgreSQL (gateway Admin manages the key).

CLAW_CLUSTER_ID=local-dev
CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:CHANGE_ME@127.0.0.1:5433/claw_gateway

CLAW_GATEWAY_LLM_CONFIG_POLL_INTERVAL_SECS=30

# Same compose network as postgres (inside tap container):
# CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:CHANGE_ME@postgres:5432/claw_gateway

# Optional
# CLAUDE_TAP_DISABLE_SELF_UPDATE=1

# =============================================================================
# Standalone dev (no CLAW_*): comment out block above, set upstream via CLI only
# =============================================================================
# claude-tap --tap-target https://api.example.com ...
